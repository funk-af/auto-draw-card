    "contract": {
        "name": "Killswitch",
        "methods": [
            {
                "name": "deploy",
                "args": [
                    {
                        "type": "address",
                        "name": "owner",
                        "desc": "The account to set as the contract owner."
                    },
                    {
                        "type": "uint64",
                        "name": "main",
                        "desc": "The Main contract used to verify card ownership when enabling delegation."
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "address"
                },
                "desc": "Deploy the contract, setting the owner as provided and initializing global state."
            },
            {
                "name": "authorize",
                "args": [
                    {
                        "type": "address",
                        "name": "account",
                        "desc": "The address of the user to check."
                    },
                    {
                        "type": "address",
                        "name": "card",
                        "desc": "The card receiving the AutoDraw axfer; must be owned by `account`."
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Checks if the delegation is authorized for the account.\n\nThe AutoDraw lsig binds `card` to the axfer receiver, so verifying here that\n`account` owns `card` prevents the delegated draw from funding (and subsequently\ndebiting) a card the account does not own."
            },
            {
                "name": "enable",
                "args": [
                    {
                        "type": "address",
                        "name": "card",
                        "desc": "A card address owned by the caller, used to prove card ownership."
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Enables AutoDraw delegation.\n\nGated to accounts that own a card in the Main contract, to prevent abuse of the\nowner-funded box MBR. The caller must supply a card address they own; ownership is\nverified against the Main contract via a cross-contract call."
            },
            {
                "name": "kill",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Disables AutoDraw delegation"
            },
            {
                "name": "owner",
                "args": [],
                "readonly": true,
                "returns": {
                    "type": "address"
                }
            },
            {
                "name": "transferOwnership",
                "args": [
                    {
                        "type": "address",
                        "name": "newOwner",
                        "desc": "The address of the new owner."
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Transfers the ownership of the contract to a new owner.\nRequires the caller to be the current owner."
            },
            {
                "name": "pauser",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "address",
                    "desc": "Pauser's address"
                }
            },
            {
                "name": "pause",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "void"
                }
            },
            {
                "name": "unpause",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "void"
                }
            },
            {
                "name": "updatePauser",
                "args": [
                    {
                        "type": "address",
                        "name": "_newPauser"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                }
            },
            {
                "name": "recoverAsset",
                "args": [
                    {
                        "type": "uint64",
                        "name": "asset",
                        "desc": "Asset ID of the asset to recover. If 0, Algo will be recovered."
                    },
                    {
                        "type": "uint64",
                        "name": "amount",
                        "desc": "Amount of the asset to recover. If Algos, remember the minimum balance requirement."
                    },
                    {
                        "type": "address",
                        "name": "recipient",
                        "desc": "Address to send the recovered asset to."
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Recover an asset sent to the contract by mistake. Only the owner can call this function."
            }
        ],
        "networks": {}
    },
    "bare_call_config": {}
}